---
import Layout from "../layouts/Layout.astro";
import Skills from "../components/Skills.jsx";
import Projects from "../components/Projects.jsx";
---

<Layout title="Portafolio | Gabriel Gustavo Lizama May">
  <div class="portfolio-container">
    <header>
      <div class="logo" style="display: flex; align-items: center; gap: 10px;">
        <img
          id="user-avatar"
          class="user-avatar"
          src=""
          alt="Avatar"
          style="display: none;"
        />
        <span
          id="logo-text"
          style="font-size: 1.5rem; font-weight: 800; letter-spacing: 2px; color: var(--primary-color);"
          >TAVICRACK</span
        >
      </div>
      <nav class="nav-links">
        <a href="#about">Sobre mí</a>
        <a href="#skills">Habilidades</a>
        <a href="/modelos">Modelos 3D</a>
        <a href="#projects">Proyectos</a>
      </nav>
      <button class="logout-btn" id="logoutBtn">Cerrar Sesión</button>
    </header>

    <main>
      {/* Hero / About Section */}
      <section class="hero-section card-container" id="about">
        <div class="hero-image" style="display: flex; justify-content: center; align-items: center;">
          <div style="width: 250px; height: 250px; border-radius: 50%; border: 3px solid var(--primary-color); overflow: hidden; box-shadow: 0 0 20px var(--primary-glow); background: #050505; display: flex; align-items: center; justify-content: center; position: relative;">
            <span style="color: #8b949e; font-size: 0.9rem; z-index: 1;">Tu foto aquí</span>
            {/* Imagen que podrás reemplazar después: */}
            {/* <img src="/assets/tu-foto.jpg" alt="Gabriel Gustavo" style="width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; z-index: 2;" /> */}
          </div>
        </div>
        <div class="hero-content">
          <h1>
            Hola, soy <span id="typewriter" style="color: var(--primary-color);"></span><span class="type-cursor">|</span>
          </h1>
          <p>
            Bienvenido a mi espacio digital. Soy un desarrollador web apasionado
            por crear experiencias interactivas. Este es mi portafolio
            interactivo donde demuestro mis habilidades fusionando la web y el
            modelado 3D en Blender.
          </p>
        </div>
      </section>

      {/* 3D Models CTA Section */}
      <section
        id="models"
        class="card-container"
        style="text-align: center;"
      >
        <h2 class="section-title" style="margin-bottom: 1rem;">Mis Modelos 3D</h2>
        <p style="color: #8b949e; margin-bottom: 2rem;">
          He diseñado y modelado todo mi setup en Blender. Entra aquí para
          explorar cada objeto y manipularlo libremente en 360°.
        </p>
        <a href="/modelos" class="blender-btn" style="margin: 0 auto;">
          <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
            <path
              d="M14.933 6.345c-2.327-.47-5.064-.5-7.466 2.37-2.316 2.766-2.585 7.15-2.022 10.45 1.554-.87 4.54-3.513 4.54-3.513s.475-.38.86-.54l.01-.005c.805-.333 1.954-.42 3.036-.32 1.48.136 3.125.688 3.5 1.442.274.55.088 1.423-.88 2.062 1.25-.425 2.096-1.127 2.257-1.84.214-.95-1.026-2.61-2.935-3.374-1.343-.538-3.04-.66-4.506-.554-1.464.106-2.884.512-3.882 1.144-.06.038-.114.08-.168.125-.194-.282-.366-.583-.518-.9-1.226-2.553-.61-5.74 1.237-7.948 1.96-2.344 4.312-2.558 6.938-2.008zM9.475 22.42c.86.347 1.83.473 2.802.473 4.707 0 8.525-3.818 8.525-8.525 0-.493-.042-.976-.12-1.445-1.026 1.107-2.736 1.843-4.57 2.152-1.397.235-3.23.19-4.82-.128 1.764.558 3.738.56 5.378-.016.92-.323 1.637-.778 2.062-1.286-.298 3.14-2.93 5.586-6.142 5.586-1.144 0-2.21-.308-3.115-.81zM11.75 14.19c.895 0 1.62.725 1.62 1.62s-.725 1.62-1.62 1.62-1.62-.725-1.62-1.62.725-1.62 1.62-1.62z"
            ></path>
          </svg>
          Modelos 3D
        </a>
      </section>

      {/* Skills Section */}
      <Skills client:load />

      {/* Projects Section */}
      <Projects client:load />
    </main>
  </div>

  <script>
    import { signOut, onAuthStateChanged } from "firebase/auth";
    import { auth } from "../firebase/client";

    let authUnsubscribe;
    let typeTimeoutId;

    document.addEventListener('astro:page-load', () => {
      // Manejar avatar de usuario
      if (authUnsubscribe) authUnsubscribe();
      authUnsubscribe = onAuthStateChanged(auth, (user) => {
        const avatarImg = document.getElementById("user-avatar");
        const logoText = document.getElementById("logo-text");
        if (user && avatarImg) {
          avatarImg.src = user.photoURL || "https://ui-avatars.com/api/?name=User&background=ffcc00&color=000";
          avatarImg.style.display = "block";
          if (logoText) logoText.style.display = "none";
        }
      });

      // Efecto de máquina de escribir
      const texts = [
        { text: "Gabriel Gustavo Lizama May", wait: 15000 },
        { text: "Full Stack Junior", wait: 10000 },
      ];
      let textIndex = 0;
      let charIndex = 0;
      let isDeleting = false;

      function type() {
        const typewriterEl = document.getElementById("typewriter");
        if (!typewriterEl) return;

        const current = texts[textIndex];
        const fullText = current.text;

        if (isDeleting) {
          typewriterEl.textContent = fullText.substring(0, charIndex - 1);
          charIndex--;
        } else {
          typewriterEl.textContent = fullText.substring(0, charIndex + 1);
          charIndex++;
        }

        let typeSpeed = isDeleting ? 30 : 80;

        if (!isDeleting && charIndex === fullText.length) {
          typeSpeed = current.wait;
          isDeleting = true;
        } else if (isDeleting && charIndex === 0) {
          isDeleting = false;
          textIndex = (textIndex + 1) % texts.length;
          typeSpeed = 500;
        }

        typeTimeoutId = setTimeout(type, typeSpeed);
      }

      if (typeTimeoutId) clearTimeout(typeTimeoutId);
      
      // Limpiar texto en caso de que ya haya algo por la transición
      const typeEl = document.getElementById("typewriter");
      if(typeEl) typeEl.textContent = "";

      // Iniciar el efecto
      setTimeout(type, 500);

      // Manejar cierre de sesión
      const logoutBtn = document.getElementById("logoutBtn");
      if (logoutBtn) {
        // Remover event listeners anteriores clonando el botón (útil en MPAs)
        const newBtn = logoutBtn.cloneNode(true);
        logoutBtn.parentNode.replaceChild(newBtn, logoutBtn);
        
        newBtn.addEventListener("click", async () => {
          try {
            await signOut(auth);
            window.location.href = "/";
          } catch (error) {
            console.error("Error al cerrar sesión", error);
          }
        });
      }
    });
  </script>
</Layout>
